# Server port (default: 5000)
PORT=5000

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/levelup?retryWrites=true&w=majority

# JWT secret key for authentication (required — use a strong random value)
JWT_SECRET=your_jwt_secret_here_use_openssl_rand_hex_32

# Client URL for CORS whitelist (default: http://localhost:5173)
CLIENT_URL=http://localhost:5173

# Node environment (development | production)
NODE_ENV=development
